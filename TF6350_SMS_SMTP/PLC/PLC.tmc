ame Static="true">nErrId</Name><Type>UDINT</Type><BitSize>32</BitSize></SubItem><SubItem><Name Static="true">sMessage_HTML</Name><Type>STRING(5000)</Type><BitSize>40008</BitSize><Default><String>&lt;!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.01 Transitional//EN" "http://www.w3.org/TR/html4/loose.dtd"&gt;&lt;html&gt;&lt;head&gt;&lt;title&gt;Alerte PLC&lt;/title&gt;&lt;/head&gt;&lt;body style="margin:0;padding:0;background-color:#f4f4f4;font-family:Arial,sans-serif;"&gt;&lt;table width="100%" cellpadding="0" cellspacing="0" style="background-color:#f4f4f4;padding:30px 0;"&gt;&lt;tr&gt;&lt;td align="center"&gt;&lt;table width="600" cellpadding="0" cellspacing="0" style="background-color:#ffffff;border-radius:8px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.1);"&gt;&lt;tr&gt;&lt;td style="background-color:#006DB7;padding:24px 32px;"&gt;&lt;h1 style="margin:0;color:#ffffff;font-size:20px;"&gt;&amp;#9881; Beckhoff PLC Notification&lt;/h1&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style="padding:32px;"&gt;&lt;h2 style="color:#333333;font-size:18px;margin-top:0;"&gt;Bonjour,&lt;/h2&gt;&lt;p style="color:#555555;font-size:15px;line-height:1.6;"&gt;Cet e-mail a ete envoye automatiquement depuis votre automate Beckhoff.&lt;/p&gt;&lt;table width="100%" cellpadding="0" cellspacing="0" style="background-color:#f0f7ff;border-left:4px solid #006DB7;border-radius:4px;margin:24px 0;"&gt;&lt;tr&gt;&lt;td style="padding:16px;"&gt;&lt;p style="margin:0;color:#333;font-size:14px;"&gt;&lt;b&gt;Machine :&lt;/b&gt; PLC-01&lt;/p&gt;&lt;p style="margin:8px 0 0;color:#333;font-size:14px;"&gt;&lt;b&gt;Statut :&lt;/b&gt; &lt;span style="color:#28a745;"&gt;&amp;#10003; Operationnel&lt;/span&gt;&lt;/p&gt;&lt;p style="margin:8px 0 0;color:#333;font-size:14px;"&gt;&lt;b&gt;Heure :&lt;/b&gt; 14:32:05&lt;/p&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;p style="color:#555555;font-size:15px;line-height:1.6;"&gt;Veuillez ne pas repondre a cet e-mail, il est envoye automatiquement.&lt;/p&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style="background-color:#f4f4f4;padding:16px 32px;border-top:1px solid #eeeeee;"&gt;&lt;p style="margin:0;color:#999999;font-size:12px;text-align:center;"&gt;Beckhoff Automation &amp;mdash; Envoi automatique depuis TwinCAT 3&lt;/p&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/body&gt;&lt;/html&gt;</String></Default></SubItem></DataType><DataType><Name>TwinCAT_PreventOnlineChangeGvl</Name><SubItem><Name Static="true">WriteLineIDs</Name><Type>BOOL</Type><BitSize>8</BitSize><Default><Bool>false</Bool></Default></SubItem><SubItem><Name Static="true">PlcProfilerActive</Name><Type>BOOL</Type><BitSize>8</BitSize><Default><Bool>false</Bool></Default></SubItem><SubItem><Name Static="true">PlcProfilerConfigChecksum</Name><Type>STRING(64)</Type><BitSize>520</BitSize><Default><String /></Default></SubItem><Properties><Property><Name>linkalways</Name></Property></Properties></DataType><DataType><Name>GVL_SMTP</Name><SubItem><Name Static="true">sTo</Name><Type>STRING(80)</Type><BitSize>648</BitSize><Default><String>yohann.moreau44@gmail.com</String></Default></SubItem><SubItem><Name Static="true">sFrom</Name><Type>STRING(80)</Type><BitSize>648</BitSize><Default><String>y.moreau@beckhoff.com</String></Default></SubItem><SubItem><Name Static="true">sSmtpServer</Name><Type>STRING(80)</Type><BitSize>648</BitSize><Default><String>smtp.gmail.com</String></Default></SubItem><SubItem><Name Static="true">sUsername</Name><Type>STRING(80)</Type><BitSize>648</BitSize><Default><String>yohann.moreau44@gmail.com</String></Default></SubItem><SubItem><Name Static="true">sPassword</Name><Type>STRING(80)</Type><BitSize>648</BitSize><Default><String>bwlr zpvn eotr ofgr</String></Default></SubItem></DataType></DataTypes><Modules><Module GUID="{51DCE589-575B-4C51-BFB5-495985B40C1B}" TcSmClass="TComPlcObjDef" TargetPlatform="TwinCAT RT (x64)"><Name>PLC</Name><CLSID ClassFactory="TcPlc30">{08500001-0000-0000-F000-000000000064}</CLSID><Licenses><