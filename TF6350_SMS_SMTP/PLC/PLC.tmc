op:1px solid #eeeeee;"&gt;&lt;p style="margin:0;color:#999999;font-size:12px;text-align:center;"&gt;Beckhoff Automation &amp;mdash; Envoi automatique depuis TwinCAT 3&lt;/p&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/body&gt;&lt;/html&gt;</String></Default><BitOffs>6032896</BitOffs></Symbol></DataArea></DataAreas><Deployment /><EventClasses /><Properties><Property><Name>ApplicationName</Name><Value>Port_851</Value></Property><Property><Name>ChangeDate</Name><Value>2026-04-24T15:44:00</Value></Property><Property><Name>DataID</Name><Value>{6f379cac-0000-0000-0000-000000000000}</Value></Property><Property><Name>GeneratedCodeSize</Name><Value>57344</Value></Property><Property><Name>GlobalDataSize</Name><Value>376832</Value></Property><Property><Name>UTF8EncodedStrings</Name><Value>false</Value></Property></Properties></Module></Modules></TcModuleClass>